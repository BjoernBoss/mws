{
	"name": "mws",
	"version": "1.0.0",
	"type": "module",
	"description": "Modular WebServer — a TypeScript framework for hosting isolated modules behind HTTP/HTTPS+WebSocket endpoints",
	"license": "BSD-3-Clause",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./*.js": {
			"types": "./dist/*.d.ts",
			"default": "./dist/*.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist/**/*.js",
		"dist/**/*.d.ts"
	],
	"scripts": {
		"build": "tsc",
		"start": "tsc && node ./main.js",
		"test": "tsc && node --test test.js"
	},
	"dependencies": {
		"ws": "^8.18.1",
		"@types/ws": "^8.18.1"
	},
	"devDependencies": {
		"@types/node": "^25.6.0",
		"typescript": "^6.0.3"
	},
	"engines": {
		"node": ">=22.0.0"
	}
}