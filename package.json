{
	"name": "@bjoernboss/mws",
	"version": "1.0.0",
	"type": "module",
	"description": "Modular Web Server — a TypeScript framework for hosting isolated modules behind HTTP/HTTPS+WebSocket endpoints",
	"license": "BSD-3-Clause",
	"author": "Bjoern Boss Henrichsen <bjoernbossdev@gmail.com>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/BjoernBoss/mws.git"
	},
	"publishConfig": {
		"access": "public"
	},
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"default": "./dist/index.js",
			"types": "./dist/index.d.ts"
		},
		"./*.js": {
			"default": "./dist/*.js",
			"types": "./dist/*.d.ts"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist/**/*.js",
		"dist/**/*.d.ts"
	],
	"scripts": {
		"prepare": "tsc"
	},
	"dependencies": {
		"ws": "^8.18.1",
		"@types/ws": "^8.18.1"
	},
	"devDependencies": {
		"@types/node": "^25.6.0",
		"typescript": "^6.0.3"
	},
	"engines": {
		"node": ">=22.0.0"
	}
}